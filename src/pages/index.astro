---
import Layout from '../layouts/Layout.astro';
import { SKILLS, CATEGORIES } from '../lib/skills';

const foundation = SKILLS.find((s) => s.slug === 'deliberate')!;
const specialized = SKILLS.filter((s) => s.slug !== 'deliberate');

const skillList = SKILLS.map((s) => ({
  slug: s.slug,
  cmd: s.command,
  tagline: s.tagline,
  cat: s.categoryLabel,
}));
---

<Layout title="Deliberate">
  <section class="hero-term">
    <div class="container">
      <div class="screen">
        <div class="screen-bar">
          <span class="dots"><i></i><i></i><i></i></span>
          <span class="bar-title">deliberate — zsh — 80×24</span>
          <span class="bar-note">v3.3.0</span>
        </div>
        <div class="screen-body">
          <pre class="wordmark" aria-label="Deliberate">{`
     ___      _ _ _                 _
    |   \  ___| (_) |__  ___ _ _ __ _| |_ ___
    | |) |/ -_) | | '_ \/ -_) '_/ _\` |  _/ -_)
    |___/ \___|_|_|_.__/\___|_| \__,_|\__\___|
`}</pre>
          <div id="boot" class="boot"></div>
          <div id="mascot" class="mascot" hidden>
            <pre>{`   ( •_•)  < think before you type.`}</pre>
          </div>
          <div id="console" class="console" hidden>
            <div id="history" class="history"></div>
            <label class="prompt-line" for="cmd">
              <span class="prompt">deliberate<span class="path">~</span>$</span>
              <input id="cmd" class="cmd-input" type="text" autocomplete="off" autocapitalize="off" spellcheck="false" aria-label="terminal command" placeholder="try: help" />
              <span class="caret term-cursor" aria-hidden="true"></span>
            </label>
          </div>
        </div>
      </div>

      <div class="hero-term-below">
        <p class="hero-term-tagline">
          Engineering discipline for AI harnesses — thirteen drop-in skills that counter the failure modes that show up once you're mostly programming in English.
        </p>
        <div class="hero-ctas">
          <a href="/install/" class="hero-cta">Get started <span class="hero-cta-arrow">→</span></a>
          <div class="works-with">
            <span class="works-with-label">Works with</span>
            <div class="harness-logos">
              <span class="harness" title="Claude Code" aria-label="Claude Code"><img src="/logos/claude.svg" alt="" width="16" height="16" /></span>
              <span class="harness" title="Cursor" aria-label="Cursor"><img src="/logos/cursor.svg" alt="" width="16" height="16" /></span>
              <span class="harness" title="Codex CLI" aria-label="Codex CLI"><img src="/logos/openai.svg" alt="" width="16" height="16" /></span>
              <span class="harness" title="Gemini CLI" aria-label="Gemini CLI"><img src="/logos/googlegemini.svg" alt="" width="16" height="16" /></span>
              <span class="harness" title="Windsurf" aria-label="Windsurf"><img src="/logos/windsurf.svg" alt="" width="16" height="16" /></span>
              <span class="harness harness-more">+35 more</span>
            </div>
          </div>
        </div>
        <div class="hero-version muted"><code>npx skills add angad-kandhari/deliberate</code></div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <div class="eyebrow">01 — Foundation</div>
        <h2>The default load for any project.</h2>
        <p class="section-lede">
          <code>/deliberate</code> teaches your agent nine principles for how to write code - when to plan, when to push back, when to stop. Everything else in this library builds on top of it.
        </p>
      </div>

      <a href={`/skills/${foundation.slug}/`} class="foundation-card">
        <div class="foundation-header">
          <span class="cmd">{foundation.command}</span>
          <span class="foundation-arrow">→</span>
        </div>
        <p class="foundation-blurb">{foundation.blurb}</p>
        <div class="foundation-counters">
          <span class="eyebrow">Counters</span>
          <p>{foundation.counters}</p>
        </div>
      </a>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div class="eyebrow">02 — Language</div>
        <h2>Twelve specialized skills.</h2>
        <p class="section-lede">
          Load these alongside the foundation when the task calls for them. Each is a standalone file - take what you need, skip what you don't.
        </p>
      </div>

      {CATEGORIES.filter((c) => c.key !== 'foundation').map((cat) => {
        const items = specialized.filter((s) => s.category === cat.key);
        return (
          <div class="category-block">
            <div class="category-head">
              <h3 class="category-title">{cat.label}</h3>
              <span class="muted category-count mono">{items.length} {items.length === 1 ? 'skill' : 'skills'}</span>
            </div>
            <p class="category-blurb muted">{cat.blurb}</p>
            <div class="skill-grid">
              {items.map((s) => (
                <a href={`/skills/${s.slug}/`} class="skill-card">
                  <div class="skill-card-top">
                    <span class="cmd">{s.command}</span>
                    <span class="skill-arrow">→</span>
                  </div>
                  <div class="skill-card-title">{s.tagline}</div>
                  <div class="skill-card-counter muted">{s.counters}</div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <div class="eyebrow">03 — Install</div>
        <h2>Drop it in. Reference it. Ship.</h2>
        <p class="section-lede">
          Every skill is plain markdown. No tool-specific syntax, no build step, no lock-in.
        </p>
      </div>

      <div class="install-grid">
        <div class="install-card install-card-primary">
          <div class="install-head">
            <span class="recommended-tag">Claude Code</span>
            <span class="eyebrow">Plugin</span>
          </div>
          <pre><code>/plugin marketplace add angad-kandhari/deliberate
/plugin install deliberate@deliberate</code></pre>
          <p class="install-blurb muted">
            All thirteen skills plus a session-start hook so they actually fire. Cross-tool? <code>npx skills add angad-kandhari/deliberate</code> works with 40+ agents.
          </p>
        </div>

        <div class="install-card">
          <div class="install-head">
            <span class="eyebrow">Manual / paste-in</span>
          </div>
          <p class="muted install-blurb">
            Prefer to control what lands in your repo? Clone the repo and reference skills from <code>CLAUDE.md</code>, <code>.cursorrules</code>, or paste into any system prompt. Plain markdown.
          </p>
          <a href="/install/" class="btn btn-ghost">Full install guide →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container-prose">
      <div class="eyebrow">Why</div>
      <h2 class="why-title">The models will keep writing code. <span class="accent">How</span> they write it is still up to us.</h2>
      <p class="why-body">
        In late 2025, Andrej Karpathy <a href="https://x.com/karpathy/status/2015883857489522876" target="_blank" rel="noopener">posted a thread</a> on what changed - and what didn't - as agent coding crossed a coherence threshold. The diagnosis was sharp:
      </p>
      <blockquote class="why-quote">
        "The models make wrong assumptions on your behalf and just run along with them without checking. They don't manage their confusion, don't seek clarifications, don't surface inconsistencies, don't present tradeoffs, don't push back when they should."
      </blockquote>
      <p class="why-body">
        Those are the failure modes Deliberate pushes against. Credit for the diagnosis is Karpathy's. This library is the practical extrapolation into files you can drop into a project.
      </p>
    </div>
  </section>

<style>
  .accent {
    color: var(--accent);
    font-style: italic;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.75rem 1.25rem;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 4px;
    transition: all 150ms ease;
  }
  .hero-cta:hover {
    background: var(--accent);
    color: var(--accent-on-strong);
  }
  .hero-cta-arrow {
    transition: transform 150ms ease;
  }
  .hero-cta:hover .hero-cta-arrow {
    transform: translateX(3px);
  }

  .works-with {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-wrap: wrap;
  }
  .works-with-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
  }
  .harness-logos {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }
  .harness {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: #f3f1ec;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 7px;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .harness:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }
  .harness img {
    width: 16px;
    height: 16px;
    display: block;
  }
  :global([data-theme='dark']) .harness {
    background: #ece9e3;
    border-color: rgba(0, 0, 0, 0.08);
  }
  .harness-more {
    width: auto;
    height: 30px;
    padding: 0 0.625rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--muted);
    background: transparent;
    border: 1px dashed var(--line);
    border-radius: 7px;
  }
  .harness-more:hover {
    transform: none;
    box-shadow: none;
  }

  .hero-version {
    font-size: 0.75rem;
    letter-spacing: 0.02em;
  }
  .hero-version code {
    font-size: 0.75rem;
    padding: 0.1em 0.35em;
  }

  .section {
    padding: 5rem 0;
  }
  .section-alt {
    background: var(--paper-2);
    border-top: 1px solid var(--line-soft);
    border-bottom: 1px solid var(--line-soft);
  }
  .section-head {
    max-width: 44rem;
    margin-bottom: 3rem;
  }
  .section-head h2 {
    margin-top: 1rem;
  }
  .section-lede {
    margin-top: 1.25rem;
    font-size: 1.0625rem;
    color: var(--ink-soft);
  }

  .foundation-card {
    display: block;
    padding: 2.5rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 8px;
    transition: all 180ms ease;
    color: inherit;
  }
  .foundation-card:hover {
    border-color: var(--brand-500);
    background: var(--accent-soft);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -12px rgba(27, 74, 43, 0.2);
  }
  .foundation-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .foundation-header .cmd {
    font-size: 1.5rem;
    font-weight: 500;
  }
  .foundation-arrow {
    font-size: 1.25rem;
    color: var(--accent);
    transition: transform 180ms ease;
  }
  .foundation-card:hover .foundation-arrow {
    transform: translateX(4px);
  }
  .foundation-blurb {
    font-size: 1.0625rem;
    color: var(--ink-soft);
    max-width: none;
    line-height: 1.6;
  }
  .foundation-counters {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--line);
  }
  .foundation-counters p {
    margin-top: 0.5rem;
    color: var(--muted);
    font-size: 0.9375rem;
    max-width: none;
  }

  .category-block {
    margin-bottom: 3rem;
  }
  .category-block:last-child { margin-bottom: 0; }
  .category-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--line-soft);
  }
  .category-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .category-count {
    font-size: 0.8125rem;
  }
  .category-blurb {
    margin-top: 0.875rem;
    font-size: 0.9375rem;
    max-width: 48rem;
  }
  .skill-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 0.75rem;
  }
  .skill-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 6px;
    transition: all 160ms ease;
    color: inherit;
  }
  .skill-card:hover {
    border-color: var(--brand-500);
    background: var(--accent-soft);
  }
  .skill-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .skill-card-top .cmd { font-size: 1rem; }
  .skill-arrow { color: var(--accent); font-size: 0.875rem; }
  .skill-card-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    color: var(--ink);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .skill-card-counter {
    font-size: 0.8125rem;
    line-height: 1.5;
    margin-top: auto;
  }

  .install-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 1rem;
  }
  .install-card {
    padding: 1.75rem;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 8px;
  }
  .install-card-primary {
    background: linear-gradient(180deg, var(--accent-soft) 0%, var(--paper-2) 100%);
    border-color: var(--accent-border);
  }
  .install-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .recommended-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-hover);
    background: var(--accent-soft-2);
    padding: 0.25rem 0.625rem;
    border-radius: 3px;
  }
  .install-card pre {
    margin: 0 0 1rem;
    font-size: 0.875rem;
  }
  .install-card-primary pre {
    font-size: 0.9375rem;
  }
  .install-blurb {
    margin: 0 0 1.25rem;
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .why-title {
    margin-top: 1rem;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
  }
  .why-body {
    margin-top: 1.5rem;
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .why-quote {
    margin: 2rem 0;
    padding: 1.5rem 1.75rem;
    background: var(--accent-soft);
    border-left: 3px solid var(--brand-500);
    border-radius: 0 6px 6px 0;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-style: italic;
    line-height: 1.5;
    color: var(--accent-hover);
  }

  @media (max-width: 720px) {
    .install-grid { grid-template-columns: 1fr; }
    .section { padding: 3.5rem 0; }
    .hero-term { padding: 2.5rem 0 3.5rem; }
  }

  /* Terminal hero */
  .hero-term { padding: 3.5rem 0 4rem; }
  .screen {
    border: 1px solid var(--accent-border);
    background: var(--paper-2);
    box-shadow: 0 0 0 1px var(--line-soft), 0 24px 80px -40px var(--term-glow);
    overflow: hidden;
    max-width: 56rem;
    margin: 0 auto;
  }
  .screen-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--accent-border);
    background: color-mix(in srgb, var(--accent) 8%, var(--paper-2));
    font-size: 0.8rem;
  }
  .dots { display: inline-flex; gap: 0.35rem; }
  .dots i { width: 0.7rem; height: 0.7rem; border-radius: 50%; background: var(--accent-border); display: inline-block; }
  .bar-title { color: var(--ink-soft); }
  .bar-note { margin-left: auto; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.7rem; }
  .screen-body {
    padding: 1.5rem clamp(1rem, 4vw, 2.5rem) 2rem;
    font-size: 0.9rem;
    line-height: 1.65;
    min-height: 20rem;
    cursor: text;
  }
  .wordmark {
    color: var(--accent);
    font-size: clamp(0.5rem, 1.7vw, 0.82rem);
    line-height: 1.1;
    text-shadow: 0 0 18px var(--term-glow);
    margin-bottom: 1rem;
    overflow-x: auto;
  }
  .boot { color: var(--ink-soft); }
  .boot .ln, .history .ln { white-space: pre-wrap; word-break: break-word; }
  .mascot { color: var(--muted); margin: 0.75rem 0; }
  .mascot pre { white-space: pre-wrap; }
  .console { margin-top: 0.5rem; }
  .history { color: var(--ink-soft); }
  .history .echo { color: var(--ink); }
  .history .accent { color: var(--accent); font-style: normal; }
  .history .dim { color: var(--muted); }
  .history .err { color: #e5484d; }
  .prompt-line { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.25rem; }
  .prompt { color: var(--accent); white-space: nowrap; }
  .prompt .path { color: var(--muted); }
  .cmd-input { flex: 1; min-width: 0; background: transparent; border: none; outline: none; color: var(--ink); font: inherit; caret-color: var(--accent); }
  .caret { margin-left: -0.5rem; }

  .hero-term-below { max-width: 56rem; margin: 2rem auto 0; }
  .hero-term-tagline { font-size: clamp(1rem, 1.6vw, 1.15rem); color: var(--ink-soft); line-height: 1.6; max-width: 44rem; margin-bottom: 1.75rem; }
  .hero-version { margin-top: 1.25rem; font-size: 0.85rem; }
</style>
</Layout>

<script is:inline define:vars={{ skillList }}>
  (function () {
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var bootEl = document.getElementById('boot');
    var mascot = document.getElementById('mascot');
    var consoleEl = document.getElementById('console');
    var history = document.getElementById('history');
    var input = document.getElementById('cmd');
    if (!bootEl) return;

    var BOOT = [
      '$ deliberate --init',
      '  [ok] mounting foundation ......... /deliberate',
      '  [ok] loading ' + skillList.length + ' skills ......... ready',
      '  [ok] sycophancy filter ........... disabled by design',
      '  [ok] verification loop ........... armed',
      '  ready. the agent will think before it types.',
      '',
    ];

    function line(text, cls) {
      var d = document.createElement('div');
      d.className = 'ln' + (cls ? ' ' + cls : '');
      d.textContent = text;
      return d;
    }

    function reveal(done) {
      if (reduce) { BOOT.forEach(function (t) { bootEl.appendChild(line(t)); }); return done(); }
      var i = 0;
      (function next() {
        if (i >= BOOT.length) return done();
        var d = line('', 'in'); bootEl.appendChild(d);
        var t = BOOT[i], j = 0, speed = t.indexOf('[ok]') > -1 ? 6 : 14;
        (function type() {
          d.textContent = t.slice(0, j);
          if (j++ <= t.length) setTimeout(type, speed);
          else { i++; setTimeout(next, 90); }
        })();
      })();
    }

    var COMMANDS = {
      help: function () {
        return ['commands:', '  ls              list every skill', '  <skill>         what a skill does   (e.g. debug)',
          '  deliberate      the foundation', '  whoami          honestly?', '  clear           wipe the screen'];
      },
      ls: function () {
        return skillList.map(function (s) {
          return '  ' + (s.cmd + '            ').slice(0, 13) + s.tagline + '   [' + s.cat.toLowerCase() + ']';
        });
      },
      whoami: function () { return ['a coding agent that is about to read the file before editing it. for once.']; },
      deliberate: function () {
        return ['/deliberate — the foundation, loaded by default.',
          'nine principles: think before coding, push back, plan inline, simplicity',
          'first, surgical changes, goal-driven, know when to stop, calibrate, keep context.'];
      },
      clear: function () { history.innerHTML = ''; return null; },
    };

    function run(raw) {
      var cmd = raw.trim().toLowerCase();
      history.appendChild(line('deliberate~$ ' + raw, 'echo'));
      if (!cmd) return;
      if (COMMANDS[cmd]) { var out = COMMANDS[cmd](); if (out) out.forEach(function (t) { history.appendChild(line(t, 'out')); }); return; }
      var hit = skillList.find(function (s) { return s.slug === cmd || s.cmd === '/' + cmd; });
      if (hit) {
        history.appendChild(line(hit.cmd + ' — ' + hit.tagline, 'out accent'));
        history.appendChild(line('  category: ' + hit.cat + '   ·   see /skills/' + hit.slug + '/', 'out'));
        return;
      }
      history.appendChild(line("command not found: " + cmd + "  (try 'help' or 'ls')", 'out err'));
    }

    reveal(function () {
      mascot.hidden = false;
      consoleEl.hidden = false;
      COMMANDS.help().forEach(function (t) { history.appendChild(line(t, 'out dim')); });
    });

    input.addEventListener('keydown', function (e) {
      if (e.key !== 'Enter') return;
      var v = input.value; input.value = ''; run(v);
    });
    document.querySelector('.screen-body').addEventListener('click', function () {
      if (!consoleEl.hidden) input.focus();
    });
  })();
</script>
