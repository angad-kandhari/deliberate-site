---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-col">
      <div class="footer-brand">
        <span class="footer-mark">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
            <rect x="1.6" y="1.6" width="20.8" height="20.8" rx="5" stroke="currentColor" stroke-width="2" />
            <path d="M7 8 L11 12 L7 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M13 16 H17.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </span>
        <strong>Deliberate</strong>
      </div>
      <p class="muted footer-tag">Engineering discipline for AI harnesses.</p>
    </div>
    <div class="footer-col">
      <div class="footer-label">Skills</div>
      <a href="/skills/">All skills</a>
      <a href="/skills/deliberate/">Foundation</a>
      <a href="/install/">Install</a>
    </div>
    <div class="footer-col">
      <div class="footer-label">More</div>
      <a href="/failure-modes/">Failure modes</a>
      <a href="https://github.com/angad-kandhari/deliberate" target="_blank" rel="noopener">GitHub ↗</a>
      <a href="https://github.com/angad-kandhari/deliberate/releases" target="_blank" rel="noopener">Releases ↗</a>
    </div>
  </div>
  <div class="container footer-rule">
    <span class="muted">Apache 2.0 licensed.</span>
    <span class="muted mono">Think before you ship.</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    padding: 4rem 0 2rem;
    border-top: 1px solid var(--line-soft);
    background: var(--paper-2);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--ink);
  }
  .footer-mark { color: var(--accent); display: inline-flex; align-items: center; }
  .footer-mark svg { display: block; }
  .footer-tag { margin-top: 0.25rem; font-size: 0.9375rem; }
  .footer-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }
  .footer-col a {
    font-size: 0.9375rem;
    color: var(--ink-soft);
  }
  .footer-col a:hover { color: var(--accent); }
  .footer-rule {
    display: flex;
    justify-content: space-between;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line-soft);
    font-size: 0.8125rem;
  }
  @media (max-width: 720px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }
</style>
